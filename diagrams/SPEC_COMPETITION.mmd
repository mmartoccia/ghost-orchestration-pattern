        SCORE_B["Spec B score\n79.7"]
        REVIEW --> SCORE_A
        REVIEW --> SCORE_B
        
        WINNER["Winner: A\n→ dispatch"]
        LOSER["Loser: B\n→ archive"]
        SCORE_A --> WINNER
        SCORE_B --> LOSER
    end

    WINNER --> DISPATCH
    LOSER --> ARCHIVE

    subgraph DISPATCH["DISPATCH"]
        D["spec-dispatches/\nWinner's spec → workers"]
    end

    subgraph ARCHIVE["ARCHIVE"]
        AR["spec-results/\nwith feedback"]
    end

    WINNER -.->|"ELO update"| ELO

    subgraph ELO["ELO RATING"]
        E1["Agent A: R₁ → R₁+16"]
        E2["Agent B: R₂ → R₂-16"]
    end

    E1 --> SPEC_ELO["spec-elo.json\n{agents: {A: rating, B: rating}}"]
    E2 --> SPEC_ELO

    subgraph READY["READY"]
        RD["ready-specs/\nApproved builds\n→ Board"]
    end

    D --> WORKERS
    subgraph WORKERS["WORKERS"]
        CW["Codex Worker\n(gpt-5.4)"]
        GW["Gemini Worker\n(gemini-2.5-pro)"]
    end

    WORKERS --> CB["spec-callbacks/"]
    CB --> JD["Judge scores result"]
    JD --> RD

