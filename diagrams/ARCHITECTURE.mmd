    BOARD -->|"task dispatch"| ORCH

    subgraph ORCH["LAYER 2 — ORCHESTRATION"]
        direction LR
        
        subgraph LOOP["Task Loop (Daemon)"]
            PN["pick_next() WIP=1 highest-prio"]
            EX["execute_task() run spawn dispatch"]
            LOG["mark done/blocked write log"]
            PN --> EX --> LOG --> PN
        end
        
        subgraph SCHED["Cron Scheduler"]
            M["1 Metrics"]
            A["2 Analyze quality cost"]
            E["3 TASTE rubric evaluate"]
            P["4 Proposals deviations"]
            M --> A --> E --> P
        end
        
        subgraph SPEC["Spec Competition"]
            SA["Agent A writes spec"]
            SB["Agent B writes spec"]
            RV["Reviewer scores both"]
            SA --> RV
            SB --> RV
        end
        
        subgraph WORKERS["Lane Workers"]
            WA["fast-lane worker"]
            WM["medium-lane worker"]
            WS["slow-lane worker"]
        end
    end

    ORCH -->|"read write"| DATA

    subgraph DATA["LAYER 3 — DATA"]
        PROD["Canonical Source append-only read-only"]
        SYNC["ETL Sync schema validation"]
        DER["Derived Store PostgreSQL SQLite"]
        PROD --> SYNC --> DER
    end

    LOOP -.-> LOG2["orchestration.log.jsonl immutable append-only"]
    SCHED -.-> LOG2

