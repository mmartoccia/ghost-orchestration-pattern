```mermaid
%%{init: {"theme": "dark"}}%%
flowchart TB
    subgraph BOARD["LAYER 1 — BOARD"]
        direction TB
        L1["Human work intake\n+ Triage"]
        LANES["fast-lane · medium-lane · slow-lane\n(coordination/*.md files)"]
        INC["incident-board.md\n(Cross-Lane Escalation)"]
        TOPICMAP["topic-map.yaml\n(channel → file routing)"]
        
        L1 --> LANES
        LANES --> INC
        L1 --> TOPICMAP
    end

    BOARD -->|"task dispatch"| ORCH

    subgraph ORCH["LAYER 2 — ORCHESTRATION"]
        direction LR
        
        subgraph LOOP["Task Loop (Daemon)"]
            PN["pick_next()\nWIP=1 · highest-prio"]
            EX["execute_task()\nrun · spawn · dispatch"]
            LOG["mark done/blocked\nwrite log (BEFORE notify)"]
            PN --> EX --> LOG --> PN
            LOG -.->|"backlog empty"| SLP["sleep 30s"]
            SLP --> PN
        end
        
        subgraph SCHED["Cron Scheduler  (see: reference/CRON_ORCHESTRATOR.md)"]
            M["[1] Metrics"]
            A["[2] Analyze\nquality · cost"]
            E["[3] TASTE rubric\nevaluate"]
            P["[4] Proposals\ndeviations"]
            M --> A --> E --> P
        end
        
        subgraph SPEC["Spec Competition  (see: reference/SPEC_COMPETITION.md)"]
            SA["Agent A\nwrites spec"]
            SB["Agent B\nwrites spec"]
            RV["Reviewer\nscores both"]
            SA & SB --> RV
            RV --> W["Winner\n→ dispatch"]
            RV -.-> ELO["ELO ratings"]
        end
        
        subgraph WORKERS["Lane Workers  (see: reference/LANE_WORKERS.md)"]
            WA["fast-lane worker\nPoll: 30-60s"]
            WM["medium-lane worker\nPoll: 2-5min"]
            WS["slow-lane worker\nPoll: 5-15min"]
        end
    end

    ORCH -->|"read / write"| DATA

    subgraph DATA["LAYER 3 — DATA"]
        PROD["Canonical Source\n(VPS DB / API / SaaS)\nappend-only, read-only for consumers"]
        SYNC["ETL / Sync\nschema validation\nscheduled or event-driven"]
        DER["Derived Store\n(PostgreSQL / SQLite)\nmaterializations + business logic"]
        
        PROD --> SYNC --> DER
    end

    LOOP -.->|"write log"| OLOG
    SCHED -.->|"write log"| OLOG

    subgraph OLOG["ORCHESTRATION LOG"]
        JL["orchestration.log.jsonl\n(immutable append-only)\nwritten BEFORE notifications"]
    end

    JL -.->|"feeds"| BOARD

    subgraph API["API  (see: reference/MC_API.md)"]
        GET["GET  /tasks\nGET  /tasks/{id}/blockers\nGET  /tasks/{id}/dependents"]
        POST["POST /tasks/{id}/status\n(atomic: log → state → handoff → notify)"]
        GET_HANDOFFS["GET  /orchestration/handoffs"]
    end

    DAEMON["Daemon\n+ Workers\n+ Scheduler"] -->|"REST"| API
    HUMAN["Humans\n(Dashboard)"] -->|"REST"| API

